{
  "name": "timeseries-manipulator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "cd server-py && uv run main.py",
    "server:node": "tsx watch server/index.ts",
    "stop": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true && lsof -ti:5173,5174 | xargs kill -9 2>/dev/null || true && echo 'All servers stopped'",
    "dev:all": "npm run server & npm run dev",
    "restart": "npm run stop & npm run dev:all",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "plotly.js": "^2.27.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/plotly.js": "^2.12.29",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}